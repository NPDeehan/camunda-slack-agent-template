<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Camunda-Slack-Agent-Template" name="Camunda-Slack-Agent-Template" isExecutable="true">
    <bpmn:sequenceFlow id="Flow_0jt0w1f" sourceRef="Activity_1jbvj8d" targetRef="Event_14an6hl" />
    <bpmn:endEvent id="Event_14an6hl" name="Slack Agent Finished">
      <bpmn:incoming>Flow_0jt0w1f</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:adHocSubProcess id="Activity_1jbvj8d" name="Your Slack Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="0" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-6" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a **Camunda Task Agent**, a helpful, generic chat agent that can handle a wide variety of customer requests using your own domain knowledge **and** any tools explicitly provided to you at runtime. &#10;The only communcation method you have with the end user is through slack and tools are provided to facilitate that converstation. Be aware that the user only has access to what you post in slack and cannot see your output otherwise.&#10;&#10;Your goal is to provide an answer to questoins about our camunda stuff or anthing the end sure might need. Make sure to answer any followup questoins that might also be asked.&#10;&#10;Any communication to the user must go throught he tools provided. &#10;&#10;If tools are provided, you should prefer them instead of guessing an answer. You can call the same tool multiple times by providing different input values. Don&#39;t guess any tools which were not explicitly configured. If no tool matches the request, try to generate an answer. If you&#39;re not able to find a good answer, return with a message stating why you&#39;re not able to.&#10;&#10;Wrap minimal, inspectable reasoning in *exactly* this XML template:&#10;&#10;&#60;thinking&#62;&#10;&#60;context&#62;…briefly state the customer’s need and current state…&#60;/context&#62;&#10;&#60;reflection&#62;…list candidate tools, justify which you will call next and why…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;Reveal **no** additional private reasoning outside these tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=string(question)" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1890yp5</bpmn:incoming>
      <bpmn:outgoing>Flow_0jt0w1f</bpmn:outgoing>
      <bpmn:serviceTask id="Activity_07bfoi2" name="Show Answer in Slack" zeebe:modelerTemplate="io.camunda.connectors.Slack.v1" zeebe:modelerTemplateVersion="9" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this tool in order to send a response to a user who is communicating over slack. Remeber that slack has specific format requirements.
When formatting messages for Slack, use Slack's mrkdwn syntax (NOT standard markdown):

- Bold: *single asterisks* (not **double**)
- Italic: _underscores_ (not *asterisks*)
- Strikethrough: ~tildes~
- Inline code: `backticks`
- Code blocks: ```triple backticks``` (no language hint — Slack ignores it)
- Blockquote: &gt; at the start of the line
- Bullet lists: use • or - at the start of a line (Slack does not render `*` as bullets)
- Numbered lists: write "1. ", "2. " manually — Slack has no auto-numbering
- Links: &lt;https://example.com|link text&gt; (angle brackets, pipe-separated)
- User mention: &lt;@USER_ID&gt;
- Channel mention: &lt;#CHANNEL_ID&gt;
- Line breaks: use real newlines (\n), not &lt;br&gt;

Do NOT use:
- Markdown headings (#, ##, ###) — they render as literal text
- Tables — Slack does not support them; use aligned text or a bulleted list
- Nested lists with deep indentation — rendering is unreliable
- HTML tags

Keep messages concise. Slack is a conversational medium, not a document. Prefer short paragraphs separated by blank lines over long blocks of text.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:slack:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="{{secrets.SLACK_HAWK_OATH_TOKEN}}" target="token" />
            <zeebe:input source="chat.postMessage" target="method" />
            <zeebe:input source="plainText" target="data.messageType" />
            <zeebe:input source="=fromAi(toolCall.answerToQuestion, &#34;This is the answer to the question the user has asked.&#34;)" target="data.text" />
            <zeebe:input source="=slackRequest.channelId" target="data.channel" />
            <zeebe:input source="=slackRequest.threadTs" target="data.thread" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="9" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.Slack.v1" />
            <zeebe:header key="resultVariable" value="responseToPost" />
            <zeebe:header key="resultExpression" value="={&#10;  myResponse: response&#10;  // Use FEEL to extract values depending on message&#10;  // type, e.g.,: myMessage: response.message.text&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_1xv0jz4</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:intermediateCatchEvent id="Event_0vckndl" name="Response" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.IntermediateCatchEvent.v1" zeebe:modelerTemplateVersion="8" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:properties>
            <zeebe:property name="inbound.type" value="io.camunda:slack-webhook:1" />
            <zeebe:property name="inbound.context" value="{{secrets.SLACK_HAWK_WEBHOOK_ID}}" />
            <zeebe:property name="inbound.slackSigningSecret" value="{{secrets.SLACK_HAWK_SIGINING_SECRET}}" />
            <zeebe:property name="inbound.verificationExpression" value="=if (body.type != null and body.type = &#34;url_verification&#34;) then {body:{&#34;challenge&#34;:body.challenge}, statusCode: 200} else null" />
            <zeebe:property name="activationCondition" value="=request.body.event.type = &#34;message&#34;&#10; and request.body.event.thread_ts != null&#10; and request.body.event.client_msg_id != null&#10; and request.body.event.bot_id = null&#10;and request.body.event.thread_ts = slackRequest.threadTs" />
            <zeebe:property name="consumeUnmatchedEvents" value="false" />
            <zeebe:property name="correlationKeyExpression" value="=string(request.body.event.thread_ts)" />
            <zeebe:property name="deduplicationModeManualFlag" value="false" />
            <zeebe:property name="deduplicationMode" value="AUTO" />
            <zeebe:property name="resultVariable" value="slackResponsInFull" />
            <zeebe:property name="resultExpression" value="={&#10;  &#34;toolCallResult&#34; : {&#10;    &#34;followUpText&#34;: request.body.event.text,&#10;    &#34;followUpUser&#34;: request.body.event.user&#10;  }&#10;}" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_03c6lz8</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_094u5ql" messageRef="Message_1ej24bd" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1xv0jz4" sourceRef="Activity_07bfoi2" targetRef="Gateway_000w0oi" />
      <bpmn:sequenceFlow id="Flow_03c6lz8" sourceRef="Gateway_000w0oi" targetRef="Event_0vckndl" />
      <bpmn:eventBasedGateway id="Gateway_000w0oi">
        <bpmn:incoming>Flow_1xv0jz4</bpmn:incoming>
        <bpmn:outgoing>Flow_03c6lz8</bpmn:outgoing>
        <bpmn:outgoing>Flow_1p8hauj</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_038j3bw" name="Wait 5 Mins for a response">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;SystemMessage&#34; : &#34;Waited for 5 mins, but there&#39;s no response.&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1p8hauj</bpmn:incoming>
        <bpmn:timerEventDefinition id="TimerEventDefinition_0piytff">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4M</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1p8hauj" sourceRef="Gateway_000w0oi" targetRef="Event_038j3bw" />
      <bpmn:scriptTask id="Activity_1wck987" name="Get the Current Time and date">
        <bpmn:documentation>Use this tool to find out the current time and date</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=now()" resultVariable="timeAndDate" />
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;TheTimeAndDate&#34; : timeAndDate&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:intermediateCatchEvent id="Event_0m8dzxr" name="Wait for Next Communication">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;Outcome&#34; : &#34;waited: &#34;+durationToWait&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0qfo9kt</bpmn:incoming>
        <bpmn:timerEventDefinition id="TimerEventDefinition_1jw3o1j">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=durationToWait</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:scriptTask id="Activity_0dcm91w" name="Calculate Wait time">
        <bpmn:documentation>Use this tool in order to wait for a specific time frame.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=true" resultVariable="triggerTimer" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.duration, &#34;This is the length of time you&#39;d like to wait. formated in ISO8601 (e.g. PT1H = 1 hour&#34;)" target="durationToWait" />
            <zeebe:output source="=durationToWait" target="durationToWait" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0dv1xfi</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_0dv1xfi" sourceRef="Activity_0dcm91w" targetRef="Gateway_1g2q0zh" />
      <bpmn:eventBasedGateway id="Gateway_1g2q0zh">
        <bpmn:incoming>Flow_0dv1xfi</bpmn:incoming>
        <bpmn:outgoing>Flow_0qfo9kt</bpmn:outgoing>
        <bpmn:outgoing>Flow_0y1tq3b</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:sequenceFlow id="Flow_0qfo9kt" sourceRef="Gateway_1g2q0zh" targetRef="Event_0m8dzxr" />
      <bpmn:intermediateCatchEvent id="Event_1v7iep8" name="Case Update">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;UpdateOnTheClaim&#34; : UpdateOnTheClaim&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0y1tq3b</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_18d8q6a" messageRef="Message_1aes4cr" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_0y1tq3b" sourceRef="Gateway_1g2q0zh" targetRef="Event_1v7iep8" />
    </bpmn:adHocSubProcess>
    <bpmn:startEvent id="Event_0kr9ms2" name="Info From Slack" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.MessageStartEvent.v1" zeebe:modelerTemplateVersion="8" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:slack-webhook:1" />
          <zeebe:property name="inbound.context" value="{{secrets.SLACK_HAWK_WEBHOOK_ID}}" />
          <zeebe:property name="inbound.slackSigningSecret" value="{{secrets.SLACK_HAWK_SIGINING_SECRET}}" />
          <zeebe:property name="inbound.verificationExpression" value="=if (body.type != null and body.type = &#34;url_verification&#34;) then {body:{&#34;challenge&#34;:body.challenge}, statusCode: 200} else null" />
          <zeebe:property name="activationCondition" value="=request.body.event.type = &#34;app_mention&#34;&#10;and not(is defined(request.headers.x-slack-retry-num))&#10;" />
          <zeebe:property name="consumeUnmatchedEvents" value="false" />
          <zeebe:property name="correlationRequired" value="required" />
          <zeebe:property name="correlationKeyExpression" value="=request.body.api_app_id = &#34;YOUR_APP_ID&#34;" />
          <zeebe:property name="deduplicationModeManualFlag" value="false" />
          <zeebe:property name="deduplicationMode" value="AUTO" />
          <zeebe:property name="resultVariable" value="question" />
          <zeebe:property name="resultExpression" value="={&#10;  &#34;slackRequest&#34; : {&#10;    &#34;senderId&#34;: request.body.event.user,&#10;    &#34;channelId&#34;: request.body.event.channel,&#10;    &#34;threadTs&#34;: request.body.event.ts,&#10;    &#34;text&#34;: request.body.event.text&#10;  }&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1890yp5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0bwlass" messageRef="Message_1frfkks" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1890yp5" sourceRef="Event_0kr9ms2" targetRef="Activity_1jbvj8d" />
    <bpmn:group id="Group_0sybyb7" categoryValueRef="CategoryValue_1ogwjoz" />
    <bpmn:group id="Group_0bgen4c" categoryValueRef="CategoryValue_1bgtv97" />
  </bpmn:process>
  <bpmn:message id="Message_1frfkks" name="" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.MessageStartEvent.v1">
    <bpmn:extensionElements />
  </bpmn:message>
  <bpmn:message id="Message_1ej24bd" name="" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.IntermediateCatchEvent.v1">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(slackRequest.threadTs)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:category id="Category_19e0t2v">
    <bpmn:categoryValue id="CategoryValue_1ogwjoz" value="Default Tools" />
  </bpmn:category>
  <bpmn:category id="Category_0778qld">
    <bpmn:categoryValue id="CategoryValue_1bgtv97" value="Put your new tools in here" />
  </bpmn:category>
  <bpmn:message id="Message_1aes4cr" name="CaseUpdate">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=slackRequest.threadTs" />
    </bpmn:extensionElements>
  </bpmn:message>
